{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@happycastle114/opencode-litellm",
  "version": "0.6.0",
  "description": "OpenCode plugin for LiteLLM proxy support with auto-detection and dynamic model discovery",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./cli": "./dist/opencode-litellm.mjs"
  },
  "bin": {
    "opencode-litellm": "./dist/opencode-litellm.mjs",
    "codex-litellm": "./dist/opencode-litellm.mjs"
  },
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "src",
    "dist",
    "skills",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run build && bun test",
    "typecheck": "tsc --noEmit",
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && npm run typecheck && tsc --emitDeclarationOnly --outDir dist && node scripts/normalize-declaration-specifiers.mjs && bun build src/index.ts --target=node --format=esm --packages=external --outfile=dist/index.mjs >/dev/null && bun build src/cli.mts --target=node --format=esm --packages=external --outfile=dist/opencode-litellm.mjs >/dev/null && chmod +x dist/opencode-litellm.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "litellm",
    "lite-llm",
    "plugin",
    "llm-proxy",
    "openai-compatible"
  ],
  "author": "happycastle114 (https://github.com/happycastle114)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/happycastle114/opencode-litellm.git"
  },
  "bugs": {
    "url": "https://github.com/happycastle114/opencode-litellm/issues"
  },
  "homepage": "https://github.com/happycastle114/opencode-litellm#readme",
  "dependencies": {
    "@opencode-ai/plugin": "1.18.4",
    "@opencode-ai/sdk": "1.18.4",
    "jsonc-parser": "3.3.1",
    "proper-lockfile": "4.1.2",
    "smol-toml": "1.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/proper-lockfile": "4.1.4",
    "typescript": "^5.9.3"
  }
}
